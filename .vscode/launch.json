{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Expo: Debug (Chrome)",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:19006",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "webpack:///src/*": "${workspaceFolder}/src/*"
      },
      "preLaunchTask": "Expo: Start Metro"
    },
    {
      "name": "Expo: Debug (React Native)",
      "type": "reactnative",
      "request": "attach",
      "port": 8081,
      "sourceMaps": true,
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "Expo: Start Metro"
    }
  ]
}